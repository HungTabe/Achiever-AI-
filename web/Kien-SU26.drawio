        <mxCell id="3oMhcfcnhV4ZUp0FiG-B-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="THU THẬP DATA" vertex="1">
          <mxGeometry height="60" width="120" x="130" y="210" as="geometry" />
        </mxCell>
        <mxCell id="Hifaieis5Mk0LkOP5z_K-4" edge="1" parent="1" source="Hifaieis5Mk0LkOP5z_K-1" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=12;startSize=8;endSize=8;" target="Hifaieis5Mk0LkOP5z_K-3" value="">
