        <mxCell id="_D-FjPjcb8cLJCChwa4u-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;table style=&quot;border-color: rgb(236, 236, 236); border-spacing: 0px; margin-bottom: 1em; width: 868.391px; font-family: &amp;quot;Lexend Deca&amp;quot;, sans-serif; font-size: medium; text-align: start; background-color: rgb(255, 255, 255); height: 162px;&quot;&gt;&lt;thead style=&quot;box-sizing: border-box;&quot;&gt;&lt;tr style=&quot;box-sizing: border-box;&quot;&gt;&lt;th style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.05; padding: 0.5em 0.5em 0.5em 0px; text-align: left; letter-spacing: 0.05em; text-transform: uppercase;&quot;&gt;STT&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.05; padding: 0.5em; text-align: left; letter-spacing: 0.05em; text-transform: uppercase;&quot;&gt;Loại giấy tờ&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.05; padding: 0.5em; text-align: left; letter-spacing: 0.05em; text-transform: uppercase;&quot;&gt;Mục đích sử dụng&lt;/th&gt;&lt;th style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.05; padding: 0.5em 0px 0.5em 0.5em; text-align: left; letter-spacing: 0.05em; text-transform: uppercase;&quot;&gt;Yêu cầu hình thức&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody style=&quot;box-sizing: border-box;&quot;&gt;&lt;tr style=&quot;box-sizing: border-box;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0.5em 0.5em 0px; color: rgb(102, 102, 102);&quot;&gt;1&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Giấy chứng nhận QSDĐ (Sổ đỏ/Sổ hồng)&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Chứng minh quyền sử dụng đất hợp pháp của người làm đơn.&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0px 0.5em 0.5em; color: rgb(102, 102, 102);&quot;&gt;Bản sao chứng thực&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0.5em 0.5em 0px; color: rgb(102, 102, 102);&quot;&gt;2&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Bản đồ địa chính, sơ đồ thửa đất&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Xác định vị trí, ranh giới và diện tích tranh chấp trên thực địa.&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0px 0.5em 0.5em; color: rgb(102, 102, 102);&quot;&gt;Bản sao hoặc trích lục&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0.5em 0.5em 0px; color: rgb(102, 102, 102);&quot;&gt;3&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Giấy tờ về nguồn gốc đất (Bằng khoán, di chúc…)&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Chứng minh quá trình hình thành và sử dụng đất qua các thời kỳ.&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0px 0.5em 0.5em; color: rgb(102, 102, 102);&quot;&gt;Bản sao kèm bản gốc đối chiếu&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0.5em 0.5em 0px; color: rgb(102, 102, 102);&quot;&gt;4&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Biên bản làm việc, hòa giải tự thỏa thuận&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Chứng minh các bên đã tự hòa giải nhưng không thành.&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0px 0.5em 0.5em; color: rgb(102, 102, 102);&quot;&gt;Bản gốc hoặc bản sao&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;box-sizing: border-box;&quot;&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0.5em 0.5em 0px; color: rgb(102, 102, 102);&quot;&gt;5&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Hình ảnh, video hiện trạng&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em; color: rgb(102, 102, 102);&quot;&gt;Cung cấp bằng chứng trực quan về hành vi lấn chiếm, xây dựng trái phép.&lt;/td&gt;&lt;td style=&quot;box-sizing: border-box; border-bottom: 1px solid rgb(236, 236, 236); font-size: 0.9em; line-height: 1.3; padding: 0.5em 0px 0.5em 0.5em; color: rgb(102, 102, 102);&quot;&gt;In ảnh hoặc lưu trữ file&lt;br&gt;&lt;br&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
