        <mxCell id="Hifaieis5Mk0LkOP5z_K-1" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="VIDEO LUẬT SƯ HÀ : LÀM GÌ KHI BỊ HX LẤN ĐẤT" vertex="1">
          <mxGeometry height="110" width="240" x="310" y="185" as="geometry" />
        </mxCell>
        <mxCell id="Hifaieis5Mk0LkOP5z_K-3" parent="1" style="whiteSpace=wrap;html=1;rounded=1;align=center;" value="&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;TRƯỚC MẮT LÀ LÀM BÀI TẬP&amp;nbsp;&lt;/span&gt;&lt;br&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;ol&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Phải lấy được quyết định từ UBND các cấp về phân định vấn đề đó&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tránh tự ý đập gây tội phá hoại&amp;nbsp;&lt;br&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Quy trình : Yêu cầu địa chính xuống căm móc phân ranh xác định lại vị trí ranh đất theo sổ đỏ nhà mình với nhà thực tế để check việc can thiệp của hàng xóm có đụng tới diện tích đất nhà mình hay không - Nếu có thì&amp;nbsp;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Gửi 1 cái đơn hòa giải tranh chấp ra ủy bản nhân dân cấp phường nơi có đất này để hòa giải tranh chấp&lt;br&gt;&lt;/li&gt;&lt;li&gt;Thường 2 lần hòa giải , Nếu không thành thì phải lấy được bản hòa giải không thành&amp;nbsp;&lt;br&gt;&lt;/li&gt;&lt;li&gt;Có rồi thì soạn đơn khởi kiện ra tòa án nhân dân cấp phường nơi có đất này - đề nghị tòa tuyên người lấn chiếm phải có trách nhiệm giao trả lại phần diện tích đã lấn chiếm và tháo dở công trình trên phần đất ấy&lt;br&gt;&lt;/li&gt;&lt;li&gt;Khi có bản án rồi thì nộp ra cơ quan thi hành án của tòa để tiến hành cưỡng chế xử lý&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="325" width="380" x="600" y="75" as="geometry" />
        </mxCell>
